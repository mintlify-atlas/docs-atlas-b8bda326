  "keyFeatures": [
    "Problem creation and management with automated grading",
    "Contest organization with real-time scoreboards",
    "Course management for structured learning paths",
    "Interactive coding arena with multiple language support",
    "Automated code evaluation using secure sandboxed runners",
    "Badge and certificate system for achievements",
    "Group management for schools and institutions",
    "Clarifications system for contest communication",
    "Quality nomination and review system for problems",
    "Admin tools for platform management"
  ],
  "publicApiSurface": [
    "/api/contest/* - Contest creation, management, and participation",
    "/api/course/* - Course creation and student enrollment",
    "/api/problem/* - Problem submission and management",
    "/api/run/* - Code submission and grading",
    "/api/user/* - User authentication and profile management",
    "/api/clarification/* - Contest clarifications",
    "/api/badge/* - Achievement badges",
    "/api/certificate/* - Certificate generation and validation",
    "/api/group/* - Group and school management",
    "/api/scoreboard/* - Contest and group scoreboards",
    "/api/admin/* - Platform administration",
    "/api/identity/* - User identity management",
    "/api/authorization/* - Access control and permissions"
  ]
